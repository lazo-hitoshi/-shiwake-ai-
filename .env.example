# Anthropic APIキー（Vercelの環境変数にも同じものを設定してください）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ユーザー一覧（JSON配列）。未設定時は認証なしで従来通り動作
# USER_LIST=[{"id":"user1","company":"A商事","password":"pass1234","plan":"basic","maxPerMonth":150,"industry":"construction"}]

# サーバー側の月間上限（全ユーザー合計・API予算の保護用）
MONTHLY_GLOBAL_CAP=200

# Vercel KV / Upstash Redis（利用枚数の永続化）
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
